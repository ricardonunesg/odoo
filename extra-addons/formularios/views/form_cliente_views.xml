<odoo>
  <data>
    <record id="view_form_reclama_cliente_form" model="ir.ui.view">
      <field name="name">form.reclama.cliente.form</field>
      <field name="model">form.reclama.cliente</field>
      <field name="arch" type="xml">
        <form>
          <header>
            <button name="action_imprimir_pdf" type="object" string="Imprimir PDF" class="btn-primary" invisible="not id"/>
          </header>
          <sheet>
            <group>
              <field name="user_id"/>
              <field name="armazem"/>
            </group>

            <group>
              <field name="cliente"/>
              <field name="codigo_artigo"/>
              <field name="descricao_artigo"/>
              <field name="lote"/>
            </group>

            <group>
              <field name="descricao_reclamacao"/>
              <field name="acoes_correcao"/>
              <div class="o_form_label">(Se já houver)</div>
            </group>

            <group string="Documento da Reclamação">
              <div class="o_form_label">(Email do cliente, whatsapp do cliente, documentos enviados pelo cliente, fotos, etc)</div>
              <field name="anexos_ids" widget="many2many_binary"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>
  </data>
</odoo>
