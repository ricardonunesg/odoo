<odoo>
  <data>
    <record id="view_form_reclama_fornecedor_list" model="ir.ui.view">
      <field name="name">form.reclama.fornecedor.list</field>
      <field name="model">form.reclama.fornecedor</field>
      <field name="arch" type="xml">
        <list>
          <field name="create_date" string="Criado em"/>
          <field name="user_id"/>
          <field name="armazem"/>
          <field name="fornecedor"/>
          <field name="assunto"/>
        </list>
      </field>
    </record>

    <record id="view_form_reclama_fornecedor_form" model="ir.ui.view">
      <field name="name">form.reclama.fornecedor.form</field>
      <field name="model">form.reclama.fornecedor</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <div class="oe_title">
              <h1><field name="assunto" placeholder="Assunto"/></h1>
            </div>

            <group>
              <field name="user_id"/>
              <field name="armazem"/>
              <field name="armazem_outro" attrs="{'invisible': [('armazem','!=','outra')]}"/>
            </group>

            <group>
              <field name="fornecedor"/>
              <field name="codigo_artigo"/>
              <field name="descricao_artigo"/>
              <field name="lote_guia_fatura"/>
            </group>

            <group>
              <field name="descricao_reclamacao"/>
              <field name="acoes_correcao"/>
            </group>

            <group string="Documento da Reclamação">
              <label string="(Email do fornecedor, whatsapp, documentos enviados pelo fornecedor, fotos, etc)"/>
              <field name="anexos_ids" widget="many2many_binary"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>
  </data>
</odoo>
