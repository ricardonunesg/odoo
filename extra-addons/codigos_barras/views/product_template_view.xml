<odoo>
    <record id="view_product_template_form_barcode" model="ir.ui.view">
        <field name="name">product.template.form.barcode</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='barcode']" position="after">
                <group string="Códigos Gerados">
                    <field name="numero_serie"/>
                    <field name="ean13_calculado" readonly="1"/>
                    <field name="codigo_base_ean13"/>
                    <field name="indicador_ean14"/>
                    <field name="ean14_calculado" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
