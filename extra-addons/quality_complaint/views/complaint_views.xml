<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_quality_customer_complaint_list" model="ir.ui.view">
        <field name="name">quality.customer.complaint.list</field>
        <field name="model">quality.customer.complaint</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date"/>
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="complaint_type"/>
                <field name="severity"/>
                <field name="responsible_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_quality_customer_complaint_form" model="ir.ui.view">
        <field name="name">quality.customer.complaint.form</field>
        <field name="model">quality.customer.complaint</field>
        <field name="arch" type="xml">
            <form string="Reclamação de Cliente" class="o_form_sheet_bg">
                <sheet>
                    <h1><field name="name" readonly="1"/></h1>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="partner_id"/>
                            <field name="contact_name"/>
                            <field name="email"/>
                            <field name="phone"/>
                        </group>
                        <group>
                            <field name="product_id"/>
                            <field name="lot_ref"/>
                            <field name="order_ref"/>
                            <field name="complaint_type"/>
                            <field name="severity"/>
                            <field name="responsible_id"/>
                            <field name="state" widget="statusbar"
                                   statusbar_visible="draft,in_progress,done,cancel"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Descrição"><field name="description"/></page>
                        <page string="Análise e Ações">
                            <group>
                                <field name="cause_analysis"/>
                                <field name="corrective_actions"/>
                                <field name="preventive_actions"/>
                            </group>
                        </page>
                        <page string="Comunicação">
                            <field name="message_ids" widget="mail_thread"/>
                            <field name="activity_ids" widget="mail_activity"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_quality_customer_complaint" model="ir.actions.act_window">
        <field name="name">Reclamações de Cliente</field>
        <field name="res_model">quality.customer.complaint</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>