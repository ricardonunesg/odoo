<odoo>
  <data>
    <record id="view_veiculo_list" model="ir.ui.view">
      <field name="name">gasoleo.veiculo.list</field>
      <field name="model">gasoleo.veiculo</field>
      <field name="arch" type="xml">
        <list>
          <field name="matricula"/>
          <field name="marca"/>
          <field name="modelo"/>
          <field name="data_compra"/>
        </list>
      </field>
    </record>

    <record id="view_veiculo_form" model="ir.ui.view">
      <field name="name">gasoleo.veiculo.form</field>
      <field name="model">gasoleo.veiculo</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <div class="oe_title">
              <h1>
                <field name="matricula" placeholder="Matrícula"/>
              </h1>
              <div>
                <field name="marca" placeholder="Marca" class="oe_inline"/>
                <field name="modelo" placeholder="Modelo" class="oe_inline"/>
              </div>
            </div>
            <group>
              <field name="marca"/>
              <field name="modelo"/>
              <field name="matricula"/>
              <field name="data_compra"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>
  </data>
</odoo>
