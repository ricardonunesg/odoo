<odoo>
  <data>
    <record id="view_deposito_list" model="ir.ui.view">
      <field name="name">gasoleo.deposito.list</field>
      <field name="model">gasoleo.deposito</field>
      <field name="arch" type="xml">
        <list>
          <field name="localizacao"/>
          <field name="litros"/>
        </list>
      </field>
    </record>

    <record id="view_deposito_form" model="ir.ui.view">
      <field name="name">gasoleo.deposito.form</field>
      <field name="model">gasoleo.deposito</field>
      <field name="arch" type="xml">
        <form edit="false">
          <sheet>
            <div class="oe_title">
              <h1>
                <field name="localizacao" placeholder="Localização"/>
              </h1>
            </div>
            <group>
              <field name="localizacao"/>
              <field name="litros"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>
  </data>
</odoo>
