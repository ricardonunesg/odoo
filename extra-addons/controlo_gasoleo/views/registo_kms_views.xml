<odoo>
  <data>
    <record id="view_registo_kms_list" model="ir.ui.view">
      <field name="name">gasoleo.registo.kms.list</field>
      <field name="model">gasoleo.registo.kms</field>
      <field name="arch" type="xml">
        <list>
          <field name="data"/>
          <field name="deposito_id"/>
          <field name="veiculo_id"/>
          <field name="condutor_id"/>
          <field name="kms"/>
          <field name="litros"/>
        </list>
      </field>
    </record>

    <record id="view_registo_kms_form" model="ir.ui.view">
      <field name="name">gasoleo.registo.kms.form</field>
      <field name="model">gasoleo.registo.kms</field>
      <field name="arch" type="xml">
        <form edit="false">
          <sheet>
            <group>
              <field name="data"/>
              <field name="deposito_id" required="1"/>
              <field name="veiculo_id"/>
              <field name="condutor_id"/>
              <field name="kms"/>
              <field name="litros"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>
  </data>
</odoo>
