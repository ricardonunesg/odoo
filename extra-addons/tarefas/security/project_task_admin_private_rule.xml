<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- Admins podem ver TODAS as tarefas privadas (sem projeto) -->
  <record id="rule_admin_see_all_private_tasks" model="ir.rule">
    <field name="name">Admins: ver todas as private tasks (To Do)</field>
    <field name="model_id" ref="project.model_project_task"/>
    <field name="domain_force">[('project_id','=',False)]</field>
    <field name="groups" eval="[(4, ref('base.group_system'))]"/>
    <field name="perm_read" eval="1"/>
    <field name="perm_write" eval="1"/>
    <field name="perm_create" eval="1"/>
    <field name="perm_unlink" eval="1"/>
  </record>
</odoo>
