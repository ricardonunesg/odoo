<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- Todos os utilizadores internos veem todas as tarefas privadas (sem projeto) -->
  <record id="rule_all_users_see_all_private_tasks" model="ir.rule">
    <field name="name">All Users: ver todos os To Do (private tasks)</field>
    <field name="model_id" ref="project.model_project_task"/>
    <field name="domain_force">[('project_id','=',False)]</field>
    <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    <field name="perm_read" eval="1"/>
    <field name="perm_write" eval="0"/>
    <field name="perm_create" eval="0"/>
    <field name="perm_unlink" eval="0"/>
  </record>
</odoo>
