<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="project_todo.project_task_action_todo_form_view" model="ir.actions.act_window.view">
    <field name="view_id" ref="project.view_task_form2"/>
  </record>

  <record id="view_task_form2_show_private_subtasks" model="ir.ui.view">
    <field name="name">project.task.form.show.private.subtasks</field>
    <field name="model">project.task</field>
    <field name="inherit_id" ref="project.view_task_form2"/>
    <field name="arch" type="xml">
      <page name="sub_tasks_page" position="attributes">
        <attribute name="invisible">False</attribute>
      </page>
    </field>
  </record>

  <record id="view_project_task_todo_list_fuller" model="ir.ui.view">
    <field name="name">project.task.todo.list.fuller</field>
    <field name="model">project.task</field>
    <field name="inherit_id" ref="project_todo.project_task_view_todo_tree"/>
    <field name="arch" type="xml">
      <field name="tag_ids" position="after">
        <field name="date_deadline"
               optional="show"
               widget="remaining_days"
               invisible="state in ['1_done', '1_canceled']"
               decoration-danger="date_deadline and date_deadline &lt; current_date"/>
      </field>
    </field>
  </record>

  <record id="view_project_task_todo_kanban_subtasks" model="ir.ui.view">
    <field name="name">project.task.todo.kanban.subtasks</field>
    <field name="model">project.task</field>
    <field name="inherit_id" ref="project_todo.project_task_view_todo_kanban"/>
    <field name="arch" type="xml">
      <field name="state" position="after">
        <field name="project_id"/>
        <field name="subtask_count"/>
        <field name="closed_subtask_count"/>
      </field>
      <field name="activity_ids" position="after">
        <t t-if="record.subtask_count.raw_value">
          <widget name="subtask_counter" class="ms-1"/>
        </t>
      </field>
      <xpath expr="//templates/t[@t-name='card']" position="inside">
        <widget name="subtask_kanban_list"/>
      </xpath>
    </field>
  </record>
</odoo>
