<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_tarefas_template_list" model="ir.ui.view">
    <field name="name">tarefas.template.list</field>
    <field name="model">tarefas.template</field>
    <field name="arch" type="xml">
      <list>
        <field name="active"/>
        <field name="name"/>
        <field name="start_date"/>
        <field name="next_run_date"/>
        <field name="interval_number"/>
        <field name="interval_type"/>
        <field name="allow_overlap"/>
      </list>
    </field>
  </record>

  <record id="view_tarefas_template_form" model="ir.ui.view">
    <field name="name">tarefas.template.form</field>
    <field name="model">tarefas.template</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="active"/>
            <field name="name"/>
          </group>

          <group string="Agenda">
            <field name="start_date"/>
            <field name="next_run_date"/>
            <field name="interval_number"/>
            <field name="interval_type"/>
            <field name="allow_overlap"/>
          </group>

          <group string="Entrega">
            <field name="user_ids" widget="many2many_tags"/>
          </group>

          <group string="Descrição">
            <field name="description" nolabel="1"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>
</odoo>
