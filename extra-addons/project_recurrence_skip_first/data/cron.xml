<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- Server Action -->
  <record id="action_generate_recurring_tasks_custom" model="ir.actions.server">
    <field name="name">Generate recurring tasks (custom)</field>
    <field name="model_id" ref="project.model_project_task_recurrence"/>
    <field name="state">code</field>
    <field name="code">model._cron_generate_recurring_tasks()</field>
  </record>

  <!-- Cron -->
  <record id="cron_generate_recurring_tasks_custom" model="ir.cron">
    <field name="cron_name">Project: Generate recurring tasks (custom)</field>
    <field name="active">True</field>
    <field name="user_id" ref="base.user_admin"/>
    <field name="interval_number">1</field>
    <field name="interval_type">hours</field>
    <field name="priority">5</field>
    <field name="ir_actions_server_id" ref="action_generate_recurring_tasks_custom"/>
    <field name="nextcall">2026-02-18 00:00:00</field>
  </record>
</odoo>
